#!/usr/bin/env bash
# Manage the orbweaver backend (device-discovery) dev server (start / stop / restart / status / logs)
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
VENV="$REPO_ROOT/.venv/bin"

PID_FILE="/tmp/orbweaver-backend.pid"
LOG_FILE="/tmp/orbweaver-backend.log"
PORT="${ORBWEAVER_PORT:-8073}"
REVIEW_DIR="${ORBWEAVER_REVIEW_DIR:-/tmp/orbweaver-reviews}"
DRYRUN_DIR="${ORBWEAVER_DRYRUN_DIR:-/tmp/orbweaver-dryrun}"
DIODE_TARGET="${ORBWEAVER_DIODE_TARGET:-}"
DIODE_CLIENT_ID="${ORBWEAVER_DIODE_CLIENT_ID:-}"
DIODE_CLIENT_SECRET="${ORBWEAVER_DIODE_CLIENT_SECRET:-}"

_pid() {
    [[ -f "$PID_FILE" ]] && cat "$PID_FILE" || echo ""
}

_running() {
    local pid
    pid=$(_pid)
    [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

cmd_start() {
    if _running; then
        echo "orbweaver-backend is already running (PID $(_pid))"
        exit 0
    fi
    mkdir -p "$REVIEW_DIR" "$DRYRUN_DIR"
    echo "Starting orbweaver-backend on port $PORT..."

    local extra_args=()
    if [[ -n "$DIODE_TARGET" ]]; then
        extra_args+=(--diode-target "$DIODE_TARGET")
        if [[ -n "$DIODE_CLIENT_ID" && -n "$DIODE_CLIENT_SECRET" ]]; then
            extra_args+=(--diode-client-id "$DIODE_CLIENT_ID" --diode-client-secret "$DIODE_CLIENT_SECRET")
        fi
    else
        extra_args+=(--dry-run --dry-run-output-dir "$DRYRUN_DIR")
        echo "  (dry-run mode — set ORBWEAVER_DIODE_TARGET to ingest for real)"
    fi

    ORBWEAVER_REVIEW_DIR="$REVIEW_DIR" \
    ORBWEAVER_CORS_ORIGINS="${ORBWEAVER_CORS_ORIGINS:-*}" \
    DIODE_TARGET="$DIODE_TARGET" \
        "$VENV/orbweaver" \
        --host 0.0.0.0 \
        --port "$PORT" \
        "${extra_args[@]}" \
        >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"

    # Wait up to 15s for the server to respond
    local i=0
    while (( i < 15 )); do
        if curl -sf --max-time 1 "http://localhost:$PORT/api/v1/status" >/dev/null 2>&1; then
            echo "Ready — http://localhost:$PORT/api/v1/status"
            exit 0
        fi
        sleep 1
        i=$(( i + 1 ))
    done
    echo "Timed out waiting for port $PORT. Check logs: $LOG_FILE"
    exit 1
}

cmd_stop() {
    local pid
    pid=$(_pid)
    if [[ -z "$pid" ]]; then
        echo "orbweaver-backend is not running (no PID file)"
        exit 0
    fi
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "orbweaver-backend is not running (stale PID $pid removed)"
        rm -f "$PID_FILE"
        exit 0
    fi
    echo "Stopping orbweaver-backend (PID $pid)..."
    kill -- -"$(ps -o pgid= -p "$pid" | tr -d ' ')" 2>/dev/null \
        || kill "$pid" 2>/dev/null
    local i=0
    while (( i < 10 )); do
        kill -0 "$pid" 2>/dev/null || break
        sleep 1
        (( i++ ))
    done
    rm -f "$PID_FILE"
    echo "Stopped."
}

cmd_restart() {
    cmd_stop
    sleep 1
    cmd_start
}

cmd_status() {
    if _running; then
        echo "orbweaver-backend is running (PID $(_pid))"
        echo "  port:       $PORT"
        echo "  review dir: $REVIEW_DIR"
        echo "  log:        $LOG_FILE"
        echo "  diode:      ${DIODE_TARGET:-dry-run}"
    else
        [[ -f "$PID_FILE" ]] && rm -f "$PID_FILE"
        echo "orbweaver-backend is stopped"
    fi
}

cmd_logs() {
    exec tail -f "$LOG_FILE"
}

case "${1:-}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_restart ;;
    status)  cmd_status ;;
    logs)    cmd_logs ;;
    *)
        echo "Usage: $(basename "$0") {start|stop|restart|status|logs}"
        exit 1
        ;;
esac
