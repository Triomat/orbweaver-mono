#!/usr/bin/env bash
# Manage the orbweaver-ui Nuxt dev server (start / stop / restart / status / logs)
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(dirname "$SCRIPT_DIR")"
UI_DIR="$REPO_ROOT/frontend"

PID_FILE="/tmp/orbweaver-ui.pid"
LOG_FILE="/tmp/orbweaver-ui.log"
PORT="${ORBWEAVER_UI_PORT:-3000}"
API_BASE="${NUXT_PUBLIC_API_BASE:-http://localhost:8073}"

_pid() {
    [[ -f "$PID_FILE" ]] && cat "$PID_FILE" || echo ""
}

_running() {
    local pid
    pid=$(_pid)
    [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null
}

cmd_start() {
    if _running; then
        echo "orbweaver-ui is already running (PID $(_pid))"
        exit 0
    fi
    echo "Starting orbweaver-ui on port $PORT (API: $API_BASE)..."
    NUXT_PUBLIC_API_BASE="$API_BASE" \
    PORT="$PORT" \
    HOST="0.0.0.0" \
        pnpm --dir "$UI_DIR" dev \
        >> "$LOG_FILE" 2>&1 &
    echo $! > "$PID_FILE"
    # Wait up to 30s for the server to respond
    local i=0
    while (( i < 30 )); do
        if curl -sf --max-time 1 "http://localhost:$PORT/" >/dev/null 2>&1; then
            echo "Ready — http://localhost:$PORT"
            exit 0
        fi
        sleep 1
        i=$(( i + 1 ))
    done
    echo "Timed out waiting for port $PORT. Check logs: $LOG_FILE"
    exit 1
}

cmd_stop() {
    local pid
    pid=$(_pid)
    if [[ -z "$pid" ]]; then
        echo "orbweaver-ui is not running (no PID file)"
        exit 0
    fi
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "orbweaver-ui is not running (stale PID $pid removed)"
        rm -f "$PID_FILE"
        exit 0
    fi
    echo "Stopping orbweaver-ui (PID $pid)..."
    # Kill the pnpm process group so child node processes are also terminated
    kill -- -"$(ps -o pgid= -p "$pid" | tr -d ' ')" 2>/dev/null \
        || kill "$pid" 2>/dev/null
    local i=0
    while (( i < 10 )); do
        kill -0 "$pid" 2>/dev/null || break
        sleep 1
        (( i++ ))
    done
    rm -f "$PID_FILE"
    echo "Stopped."
}

cmd_restart() {
    cmd_stop
    sleep 1
    cmd_start
}

cmd_status() {
    if _running; then
        echo "orbweaver-ui is running (PID $(_pid))"
        echo "  port:    $PORT"
        echo "  api:     $API_BASE"
        echo "  log:     $LOG_FILE"
    else
        [[ -f "$PID_FILE" ]] && rm -f "$PID_FILE"
        echo "orbweaver-ui is stopped"
    fi
}

cmd_logs() {
    exec tail -f "$LOG_FILE"
}

case "${1:-}" in
    start)   cmd_start ;;
    stop)    cmd_stop ;;
    restart) cmd_restart ;;
    status)  cmd_status ;;
    logs)    cmd_logs ;;
    *)
        echo "Usage: $(basename "$0") {start|stop|restart|status|logs}"
        exit 1
        ;;
esac
