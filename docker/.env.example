# orbweaver environment variables
# Copy this file to docker/.env and fill in your values.
# docker/.env is gitignored — never commit real credentials.
# Tip: run ./setup.sh for an interactive setup wizard.

# ── Diode connection ─────────────────────────────────────────────────────────
# IP or hostname of the host running diode
DIODE_HOST=CHANGEME

# gRPC port for Diode (default: 8080)
DIODE_PORT=8080

# Diode client identifier (matches your Diode app config)
DIODE_CLIENT_ID=diode-ingest

# Diode API key / client secret (from Diode admin or .env on the Diode server)
DIODE_CLIENT_SECRET=CHANGEME

# ── NetBox API ───────────────────────────────────────────────────────────────
# IP or hostname of the NetBox server
NETBOX_HOST=CHANGEME

# NetBox HTTP port (default: 8000)
NETBOX_PORT=8000

# NetBox API token (create one at NetBox → Admin → API Tokens)
NETBOX_TOKEN=CHANGEME

# ── orbweaver host ────────────────────────────────────────────────────────────
# IP or hostname that the USER'S BROWSER can reach to call the backend API.
# Set this to the host's IP or domain — NOT a Docker service name.
ORBWEAVER_HOST=CHANGEME

# ── SSH config (optional) ─────────────────────────────────────────────────────
# Override if ssh-napalm.conf is not at ../../orb/ssh-napalm.conf
# SSH_CONFIG=/absolute/path/to/ssh-napalm.conf

# ── Cleanup script ───────────────────────────────────────────────────────────
# Tag used to identify orbweaver-ingested objects for cleanup
CLEANUP_TAG=discovered
